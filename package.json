{
  "name": "easy-llm-gate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n proxy,admin,web -c blue,green,magenta \"tsx watch src/proxy.ts\" \"tsx watch src/admin.ts\" \"cd web && npx vite dev --port 5173\"",
    "build:web": "cd web && npx vite build",
    "build": "tsc && npm run build:web",
    "start": "node dist/proxy.js & node dist/admin.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
