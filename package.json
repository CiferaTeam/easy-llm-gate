{
  "name": "easy-llm-gate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"tsx watch src/server.ts\" \"cd web && npx vite dev\"",
    "build:web": "cd web && npx vite build",
    "build": "tsc && npm run build:web",
    "start": "node dist/server.js",
    "up": "npm run build && npm start"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "better-sqlite3": "^11.8.1",
    "hono": "^4.7.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
